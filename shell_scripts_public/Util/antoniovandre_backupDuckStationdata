#!/bin/bash

# Script de backup do dos dados pessoais do DuckStation, de Antonio VandrĂ©.

# DependĂŞncias: "dbxcli-linux-amd64", "md5sum".

# Ăšltima atualizaĂ§ĂŁo: 25-04-2026. NĂŁo considerando alteraĂ§Ăµes em variĂˇveis globais.

if ! [ -n "$AVENV" ] &>> /dev/null; then echo -ne "Carregando variĂˇveis de ambiente... "; if ! source "${HOME}/shell_scripts/Util/antoniovandre_env" &>> /dev/null; then echo -e "Ocorreu um erro.\n"; else echo -e "${AV_VERDE}Ok${AV_SEMCOR}.\n"; fi; fi

if ! [ -n "$AVCORES" ] &>> /dev/null &>> /dev/null; then echo -ne "Carregando antoniovandre_cores... "; if ! source "antoniovandre_cores" &>> /dev/null; then echo -e "Ocorreu um erro.\n"; else echo -e "${AV_VERDE}Ok${AV_SEMCOR}.\n"; fi; fi

if ! hash md5sum &>> /dev/null; then echo -e "${AV_VERMELHO}Software \"md5sum\" nĂŁo encontrado${AV_SEMCOR}."; exit 1; fi

if ! hash dbxcli-linux-amd64 &>> /dev/null; then echo -e "${AV_VERMELHO}Software \"dbxcli-linux-amd64\" nĂŁo encontrado${AV_SEMCOR}."; exit 1; fi

echo -e "Realizando backups de dados pessoais do DuckStation...\n"

FLAGSUSS="0"; FLAGERR="0"

IFS=$'\n'

STOPATH="/home/antoniovandre/.local/share/duckstation/memcards/"
CLOUDSTOPATH="/DuckStation memcards/"

for FILE in `find "${STOPATH}" -type f 2>> /dev/null`; do echo -n "${FILE/#*${STOPATH}} ..."; MD5ORIG=$(md5sum "${FILE}" | awk '{print $1}'); TEMP=$(dbxcli-linux-amd64 ls "${CLOUDSTOPATH}${FILE/#*${STOPATH}}" 2>> /dev/null); TEMP="${TEMP%"${TEMP##*[![:space:]]}"}"; if [ "${TEMP/#*${CLOUDSTOPATH}}" != "" ] && [ "${TEMP/#*${CLOUDSTOPATH}}" == "${FILE/#*${STOPATH}}" ]; then MD5DEST=$(OLDDIR=$PWD; cd "${TEMPDIR}"; dbxcli-linux-amd64 get "${CLOUDSTOPATH}/${FILE/#*${STOPATH}}" &>> /dev/null; md5sum "${FILE##*/}" 2>> /dev/null | awk '{print $1}'; rm "${FILE/#*${STOPATH}}" &>> /dev/null; cd "${OLDDIR}"); if [ "${MD5DEST}" != "" ] && [ "${MD5ORIG}" != "${MD5DEST}" ]; then if dbxcli-linux-amd64 put "${FILE}" "${CLOUDSTOPATH}${FILE/#*${STOPATH}}" &>> /dev/null; then echo -e " ${AV_VERDE}Ok${AV_SEMCOR}."; FLAGSUSS="1"; else echo -e "${AV_VERMELHO}Ocorreu um erro${AV_SEMCOR}."; FLAGERR="1"; fi; else echo -e " ${AV_CIANO}NĂŁo Ă© necessĂˇrio${AV_SEMCOR}."; fi; else dbxcli-linux-amd64 put "${FILE}" "${CLOUDSTOPATH}${FILE/#*${STOPATH}}" &>> /dev/null; echo -e " ${AV_VERDE}Ok${AV_SEMCOR}."; FLAGSUSS="1"; fi; done

STOPATH="/home/antoniovandre/.local/share/duckstation/savestates/"
CLOUDSTOPATH="/DuckStation savestates/"

for FILE in `find "${STOPATH}" -type f 2>> /dev/null`; do echo -n "${FILE/#*${STOPATH}} ..."; MD5ORIG=$(md5sum "${FILE}" | awk '{print $1}'); TEMP=$(dbxcli-linux-amd64 ls "${CLOUDSTOPATH}${FILE/#*${STOPATH}}" 2>> /dev/null); TEMP="${TEMP%"${TEMP##*[![:space:]]}"}"; if [ "${TEMP/#*${CLOUDSTOPATH}}" != "" ] && [ "${TEMP/#*${CLOUDSTOPATH}}" == "${FILE/#*${STOPATH}}" ]; then MD5DEST=$(OLDDIR=$PWD; cd "${TEMPDIR}"; dbxcli-linux-amd64 get "${CLOUDSTOPATH}/${FILE/#*${STOPATH}}" &>> /dev/null; md5sum "${FILE##*/}" 2>> /dev/null | awk '{print $1}'; rm "${FILE/#*${STOPATH}}" &>> /dev/null; cd "${OLDDIR}"); if [ "${MD5DEST}" != "" ] && [ "${MD5ORIG}" != "${MD5DEST}" ]; then if dbxcli-linux-amd64 put "${FILE}" "${CLOUDSTOPATH}${FILE/#*${STOPATH}}" &>> /dev/null; then echo -e " ${AV_VERDE}Ok${AV_SEMCOR}."; FLAGSUSS="1"; else echo -e "${AV_VERMELHO}Ocorreu um erro${AV_SEMCOR}."; FLAGERR="1"; fi; else echo -e " ${AV_CIANO}NĂŁo Ă© necessĂˇrio${AV_SEMCOR}."; fi; else dbxcli-linux-amd64 put "${FILE}" "${CLOUDSTOPATH}${FILE/#*${STOPATH}}" &>> /dev/null; echo -e " ${AV_VERDE}Ok${AV_SEMCOR}."; FLAGSUSS="1"; fi; done

if [ "${FLAGSUSS}" == "1" ]; then
	if [ "${FLAGERR}" == "0" ]; then
		echo -e "\n${AV_VERDE}Backups concluĂ­dos${AV_SEMCOR}.";
	else
		echo -e "\n${AV_AMARELO}Backups concluĂ­dos com alguns erros${AV_SEMCOR}.";
	fi
else
	if [ "${FLAGERR}" == "0" ]; then
		echo -e "\n${AV_VERDE}Nenhum trabalho foi necessĂˇrio${AV_SEMCOR}.";
	else
		echo -e "\n${AV_VERMELHO}Falha ao realizar os backups${AV_SEMCOR}.";
	fi
fi
