DELIMITADOR=$(TEMP=$(antoniovandre_eval_script "system delimitadorstring" | tr -d "\n"); echo -ne \\x$(printf %02x ${TEMP%.*}))

TOKENINICIOEVAL=$(TEMP=$(antoniovandre_eval_script "system tokeninicioeval" | tr -d "\n"); echo -ne \\x$(printf %02x ${TEMP%.*}))

